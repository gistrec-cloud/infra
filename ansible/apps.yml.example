---
# Copy to apps.yml (gitignored) and describe your real deployments.
# The registry is the single place that answers "what runs where" — it must
# survive any single host, which is why it lives here and not on the hosts.
# Consumed by scripts/backup-envs.sh (env backups + drift audit).
#
# <name>:                  # canonical app name; 1P items: "dotenv <name>[-<suffix>]"
#   host: <inventory hostname>
#   dir:  <path under the login user's home; "." = home itself>
#   env:  [env files in dir]          # default: [.env]; explicit [] = none
#                                     # (static sites, system endpoints)
#   repo: <github repo — documentation>
#   ci:   [workflow names in repo — move-apps.sh re-runs them after a move]
#   notes: <free text>
#   cron: [cron jobs the app needs — installed by the appcron role, keyed
#          "<app>: <name>"; minute/hour/day/month/weekday default to "*"]
#   port: <the app's loopback port — GLOBALLY unique across the fleet, so any
#          set of apps can co-locate on any host without collisions>
#   vhosts: [verbatim nginx server-block files the app needs, by name:
#            files/vhosts/<name>.conf (gitignored) — deployed by the nginx role.
#            Naming: primary FQDN, dots -> dashes (api.example.com ->
#            api-example-com); a separate domain = a separate file, even for
#            redirects and staging; www/aliases live in the primary's file;
#            domainless internal stubs are named by purpose (stub-status)]
#   process:                   # apppm2 role — the app's processes exist on the host
#     type: clone | artifact   # clone: git + runtime bootstrap; artifact: CI rsyncs builds
#     runtime: python | node   # venv + pip requirements / npm ci (clone type)
#     venv: .venv              # python venv dir, relative to dir
#     repo_dir: <path>         # clone destination when the repo root is above dir
#     ecosystem: <file>        # pm2 file, relative to dir (default ecosystem.config.js)
#     pm2: [names]             # pm2 process names to ensure exist (env from 1P first)
#   static:                    # appstatic role — built bundle the vhost serves
#     build: <shell>           # runs in dir when root is missing (fresh host / DR)
#     root: <path under dir>
#   docker:                    # appdocker role — dependencies, started before apps
#     containers: [{name, image, command, network_mode, volumes, env, restart_policy}]
#     compose: <dir>           # docker compose project dir (relative to home; "." = home)
#   deploy_keys:               # CI keys, installed with command=...,restrict
#     - {key: "ssh-ed25519 AAA... comment", command: "/usr/bin/rrsync -wo <dir>"}
#   control_scripts: [names]   # forced-command scripts: files/bin/<name> (gitignored) -> ~/bin

apps:
  my-api:
    host: web-01
    dir: my-api
    repo: you/my-api
    cron:
      - name: nightly cleanup
        minute: "0"
        hour: "3"
        job: "curl -fsS -H 'Authorization: Bearer {{ vault_my_api_cron_token }}' https://my-api.example.com/api/cron/cleanup >/dev/null 2>&1"
  my-bot:
    host: web-01
    dir: bots/my-bot
    env: [.env.prod, .env.staging]    # items: dotenv my-bot-prod / -staging
    notes: also needs redis on the same host
