---
# Copy to apps.yml (gitignored) and describe your real deployments.
# The registry is the single place that answers "what runs where" — it must
# survive any single host, which is why it lives here and not on the hosts.
# Consumed by scripts/backup-envs.sh (env backups + drift audit).
#
# <name>:                  # canonical app name; 1P items: "dotenv <name>[-<suffix>]"
#   host: <inventory hostname>
#   dir:  <path under the login user's home; "." = home itself>
#   env:  [env files in dir]          # default: [.env]
#   repo: <github repo — documentation>
#   notes: <free text>
#   cron: [cron jobs the app needs — installed by the appcron role, keyed
#          "<app>: <name>"; minute/hour/day/month/weekday default to "*"]

apps:
  my-api:
    host: web-01
    dir: my-api
    repo: you/my-api
    cron:
      - name: nightly cleanup
        minute: "0"
        hour: "3"
        job: "curl -fsS -H 'Authorization: Bearer {{ vault_my_api_cron_token }}' https://my-api.example.com/api/cron/cleanup >/dev/null 2>&1"
  my-bot:
    host: web-01
    dir: bots/my-bot
    env: [.env.prod, .env.staging]    # items: dotenv my-bot-prod / -staging
    notes: also needs redis on the same host
