# Copy to <name>.conf (gitignored) and reference it from the app's
# `vhosts: [<name>]` in apps.yml — the nginx role deploys the file verbatim
# to /etc/nginx/sites-available/<name>.conf and symlinks it into
# sites-enabled. No templating: what you save is what runs.
#
# The shared snippets (honeypot.conf, deny-dotfiles.conf) and the honeypot
# log_format are installed by the nginx role on every web host.
#
# On a FRESH host issue the TLS certificate before enabling the vhost
# (certbot paths below must exist, or nginx -t fails).
server {
    listen 80;
    listen [::]:80;

    server_name my-site.example.com;

    return 301 https://$host$request_uri;
}

server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;

    server_name my-site.example.com;

    ssl_certificate     /etc/letsencrypt/live/my-site.example.com/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/my-site.example.com/privkey.pem;

    include             /etc/letsencrypt/options-ssl-nginx.conf;
    ssl_dhparam         /etc/letsencrypt/ssl-dhparams.pem;

    include /etc/nginx/snippets/security-headers.conf;
    include /etc/nginx/snippets/honeypot.conf;
    include /etc/nginx/snippets/deny-dotfiles.conf;

    location / {
        proxy_pass http://127.0.0.1:8000;
        proxy_http_version 1.1;
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto https;
    }
}
