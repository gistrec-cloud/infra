---
# Per-host configuration for web-01.
# Copy to web-01.yml (gitignored) and adjust. Real repo URLs / domains stay here.

# nginx role: reverse-proxy vhosts on this host.
nginx_sites:
  - server_name: app.example.com
    upstream_port: 8080
    tls: true
  - server_name: api.example.com
    upstream_port: 8081
    tls: true

# nginx TLS via certbot (omit to skip cert issuance)
certbot_email: admin@example.com

# netdata role: pm2 process-down alerts are derived automatically from
# nodeapp_node_apps below (pattern `*<cwd>/<script>*`). Define netdata_pm2_apps
# here only for extra groups or to override a derived pattern (same name wins).

# netdata streaming parent: listen beyond localhost and let children reach
# port 19999 (source-restricted; firewall role). Children keep the defaults.
# netdata_bind_to: "0.0.0.0"
# firewall_allow_tcp:
#   - { port: 19999, from: 203.0.113.7 }

# netdata role: go.d httpcheck probes and the health alarms that bind to them.
# When netdata_httpcheck_jobs is non-empty the role OWNS go.d/httpcheck.conf —
# add probes here, not by editing the file on the host.
# netdata_httpcheck_jobs:
#   - name: myapp
#     url: http://127.0.0.1:9000/healthcheck
# netdata_health_files:
#   - files/netdata/health.d/myapp.conf

# nodeapp role: Node apps managed by pm2 on this host.
nodeapp_node_apps:
  - name: app
    repo: "git@github.com:example/app.git"
    branch: main
    cwd: /srv/app
    script: dist/server.js
    instances: 1
    exec_mode: fork
    env:
      NODE_ENV: production
      PORT: "8080"
