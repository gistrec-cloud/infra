---
# Copy to hosts.yml (gitignored) and replace with your real hosts.
# Example IPs are from the RFC 5737 documentation range — not real.
all:
  vars:
    ansible_python_interpreter: /usr/bin/python3
    # Fleet-wide login user + key naming convention; override per host where
    # it differs. admin_user in group_vars/all.yml follows ansible_user.
    ansible_user: your-login-user
    ansible_ssh_private_key_file: "~/.ssh/vps-{{ inventory_hostname }}.pub"
    # Break-glass public keys (hardware-backed, e.g. YubiKey-resident sk-*):
    # installed by the breakglass role into root-owned /etc/ssh/rescue_keys on
    # hosts with breakglass_managed: true. Public halves only — non-secret,
    # but live data, so real values stay in the gitignored copy.
    # breakglass_ssh_keys:
    #   - "sk-ssh-ed25519@openssh.com AAAA... breakglass@fleet"
    # Per-zone wildcard TLS (tls role, DNS-01 via Cloudflare): zone => extra
    # SANs beyond the apex. Wildcards cover ONE label — list deeper levels
    # explicitly. Token (DNS:Edit on these zones): vault_cf_acme_token in the
    # vault, or override tls_cf_api_token here with a 1Password lookup —
    # served via site.yml's once-per-run resolver, or every evaluation
    # re-prompts the 1Password app.
    # tls_acme_email: you@example.com
    # tls_zones:
    #   example.com: ["*.example.com"]
    #   example.org: ["*.example.org", "*.vps.example.org"]
  # Groups are derived, not listed: `web` from the apps registry (site.yml;
  # a temporary static web: block still merges — warm-standby only), the
  # wireguard mesh from wireguard_ip in host_vars (members also need
  # wireguard_pubkey there + vault_wg_privkey_<host> in the vault).
  hosts:
    web-01:
      ansible_host: 203.0.113.10
    web-02:
      ansible_host: 203.0.113.11
  children:
    # Self-hosted MySQL (Docker). db-01 = primary, db-02 = replica; a host can be
    # in web and db both. mysql_role / mysql_managed live in host_vars.
    db:
      hosts:
        db-01:
          ansible_host: 203.0.113.12
        db-02:
          ansible_host: 203.0.113.13
