---
# Copy to hosts.yml (gitignored) and replace with your real hosts.
# Example IPs are from the RFC 5737 documentation range — not real.
all:
  vars:
    # ansible_user is set per host: the actual SSH login user. admin_user in
    # group_vars/all.yml follows it — there is no shared service account.
    ansible_python_interpreter: /usr/bin/python3
    # Break-glass public keys (hardware-backed, e.g. YubiKey-resident sk-*):
    # installed by the breakglass role into root-owned /etc/ssh/rescue_keys on
    # hosts with breakglass_managed: true. Public halves only — non-secret,
    # but live data, so real values stay in the gitignored copy.
    # breakglass_ssh_keys:
    #   - "sk-ssh-ed25519@openssh.com AAAA... breakglass@fleet"
  children:
    web:
      hosts:
        web-01:
          ansible_host: 203.0.113.10
          ansible_user: your-login-user
        web-02:
          ansible_host: 203.0.113.11
          ansible_user: your-login-user
    # WireGuard mesh members. EVERY host listed here must define wireguard_ip +
    # wireguard_pubkey in its host_vars and vault_wg_privkey_<host> in the vault
    # (a member missing these breaks peer config rendering). A host's public
    # endpoint is its ansible_host above.
    wireguard:
      hosts:
        db-01:
        db-02:
    # Self-hosted MySQL (Docker). db-01 = primary, db-02 = replica; a host can be
    # in web and db both. mysql_role / mysql_managed live in host_vars.
    db:
      hosts:
        db-01:
          ansible_host: 203.0.113.12
        db-02:
          ansible_host: 203.0.113.13
    # netdata + baseline apply to `all`; add non-web hosts here as needed.
