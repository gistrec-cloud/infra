# {{ ansible_managed }}
# alarm-notify.sh sources the stock health_alarm_notify.conf first and this
# override second, so only the deltas live here. The file is read on every
# notification; changes apply without restarting netdata.

# Telegram — fleet-wide default recipient: every alarm role falls back here.
SEND_TELEGRAM="YES"
TELEGRAM_BOT_TOKEN="{{ netdata_telegram_bot_token }}"
DEFAULT_RECIPIENT_TELEGRAM="{{ netdata_telegram_chat_id }}"
{% if netdata_pushover_token | length > 0 %}

# Pushover — the "wake me" escalation layer. Deliberately NOT a default
# recipient: only alarms addressed (`to:`) to a role in netdata_pushover_roles
# page the phone. The stock alarm-notify maps CRITICAL → priority 1 (bypasses
# quiet hours), CLEAR → -1 (silent).
SEND_PUSHOVER="YES"
PUSHOVER_APP_TOKEN="{{ netdata_pushover_token }}"
DEFAULT_RECIPIENT_PUSHOVER="disabled"
{% for role, keys in netdata_pushover_roles.items() %}
role_recipients_pushover[{{ role }}]="{{ keys }}"
{% endfor %}
{% endif %}
