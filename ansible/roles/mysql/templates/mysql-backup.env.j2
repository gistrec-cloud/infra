# {{ ansible_managed }}
# 0600 root-only, loaded by mysql-backup.service (EnvironmentFile) — the S3 key
# never hits a process list. rclone inline S3 remote "offsite" (Yandex Object
# Storage) via env; no rclone.conf on disk.
RCLONE_CONFIG_OFFSITE_TYPE=s3
RCLONE_CONFIG_OFFSITE_PROVIDER=Other
RCLONE_CONFIG_OFFSITE_ACCESS_KEY_ID={{ mysql_backup_s3_key_id }}
RCLONE_CONFIG_OFFSITE_SECRET_ACCESS_KEY={{ mysql_backup_s3_secret }}
RCLONE_CONFIG_OFFSITE_ENDPOINT={{ mysql_backup_s3_endpoint }}
RCLONE_CONFIG_OFFSITE_REGION={{ mysql_backup_s3_region }}
S3_BUCKET={{ mysql_backup_s3_bucket }}
AGE_RECIPIENT={{ mysql_backup_age_recipient }}
