#!/usr/bin/env bash
# {{ ansible_managed }}
# Per-database mysqldump → gzip under the backup dir, then prune old dumps.
# Runs mysqldump *inside* the container; MYSQL_PWD is read from the container env
# so the root password never appears on any process list.
#
# Each dump streams into a .partial and is renamed only on success — a mysqldump
# that dies mid-stream would otherwise leave a truncated but valid-looking
# .sql.gz (gzip exits 0). The if-context neutralizes set -e for the pipeline
# (pipefail still surfaces the mysqldump status), so one failed database skips
# neither the remaining databases nor the rotation; the exit code stays non-zero
# so the systemd unit fails visibly.
set -euo pipefail

BACKUP_DIR="{{ mysql_backup_dir }}"
CONTAINER="{{ mysql_container_name }}"
RETENTION={{ mysql_backup_retention_days }}
STAMP="$(date +%Y%m%d-%H%M%S)"

mkdir -p "$BACKUP_DIR"
fail=0
{% if mysql_backup_offsite_enabled %}

# Off-site: age-encrypt each fresh dump (private identity ONLY in 1Password) and
# upload it. Creds come from the systemd EnvironmentFile.
upload_offsite() {
  local f="$1" enc
  enc="$f.age"
  if ! age -r "$AGE_RECIPIENT" -o "$enc" "$f"; then
    echo "FAIL: age-encrypt of $(basename "$f")" >&2
    return 1
  fi
  # write-only key (storage.uploader): skip rclone's read-ish bucket/object HEADs.
  if ! rclone --s3-no-check-bucket --s3-no-head --no-traverse \
        copyto "$enc" "offsite:$S3_BUCKET/{{ mysql_backup_s3_prefix }}$(basename "$enc")"; then
    echo "FAIL: off-site upload of $(basename "$enc")" >&2
    rm -f "$enc"
    return 1
  fi
  rm -f "$enc"
}
{% endif %}
{% for db in mysql_databases %}
tmp="$BACKUP_DIR/{{ db }}-$STAMP.sql.gz.partial"
if docker exec "$CONTAINER" sh -c \
  'MYSQL_PWD="$MYSQL_ROOT_PASSWORD" exec mysqldump --single-transaction --routines --triggers --databases -uroot "{{ db }}"' \
  | gzip > "$tmp"; then
  mv "$tmp" "${tmp%.partial}"
{% if mysql_backup_offsite_enabled %}
  upload_offsite "${tmp%.partial}" || fail=1
{% endif %}
else
  echo "FAIL: dump of {{ db }} failed" >&2
  rm -f "$tmp"
  fail=1
fi
{% endfor %}

# Rotation: drop dumps older than the retention window. The glob never matches
# .partial files; orphaned partials (script killed mid-dump) are swept
# separately once they are a day old.
find "$BACKUP_DIR" -maxdepth 1 -name '*.sql.gz' -type f -mtime +"$RETENTION" -delete
find "$BACKUP_DIR" -maxdepth 1 -name '*.sql.gz.partial' -type f -mtime +0 -delete
exit "$fail"
