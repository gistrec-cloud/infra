# {{ ansible_managed }}
# http{} scope via conf.d. Trust CF edges to declare the real client IP in
# CF-Connecting-IP; direct (non-CF) connections are untouched — realip only
# fires when $remote_addr matches set_real_ip_from, so the header can't be
# spoofed from outside Cloudflare. Without this, honeypot.log records edge
# IPs and the fail2ban jail bans Cloudflare instead of the scanner.
{% for range in cloudflare_edge_ranges %}
set_real_ip_from {{ range }};
{% endfor %}
real_ip_header CF-Connecting-IP;
