# {{ ansible_managed }}
{% macro proxy_location() %}
    location / {
        proxy_pass http://127.0.0.1:{{ item.upstream_port }};
        proxy_http_version 1.1;
        proxy_set_header Host              $host;
        proxy_set_header X-Real-IP         $remote_addr;
        proxy_set_header X-Forwarded-For   $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        proxy_set_header Upgrade           $http_upgrade;
        proxy_set_header Connection        "upgrade";
    }
{% endmacro %}
{% if item.tls | default(false) %}
server {
    listen 80;
    listen [::]:80;
    server_name {{ item.server_name }};

    return 301 https://$host$request_uri;
}

# The lineage must exist before this file lands — the role's certonly task
# runs first.
server {
    listen 443 ssl http2;
    listen [::]:443 ssl http2;
    server_name {{ item.server_name }};

    ssl_certificate     /etc/letsencrypt/live/{{ item.server_name }}/fullchain.pem;
    ssl_certificate_key /etc/letsencrypt/live/{{ item.server_name }}/privkey.pem;

    # Inline — nginx_sites hosts need not run the tls role, and certonly
    # never writes the /etc/letsencrypt include files.
    ssl_protocols TLSv1.2 TLSv1.3;
    ssl_prefer_server_ciphers off;
    ssl_session_cache shared:le_nginx_SSL:10m;
    ssl_session_timeout 1440m;
    ssl_session_tickets off;

{{ proxy_location() }}
}
{% else %}
server {
    listen 80;
    listen [::]:80;
    server_name {{ item.server_name }};

{{ proxy_location() }}
}
{% endif %}
