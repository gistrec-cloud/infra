# {{ ansible_managed }}
# 0600 root-only, loaded by clickhouse-backup.service (EnvironmentFile) — the S3
# key never hits a process list. rclone inline S3 remote "offsite" (Yandex Object
# Storage) via env; no rclone.conf on disk.
RCLONE_CONFIG_OFFSITE_TYPE=s3
RCLONE_CONFIG_OFFSITE_PROVIDER=Other
RCLONE_CONFIG_OFFSITE_ACCESS_KEY_ID={{ clickhouse_backup_s3_key_id }}
RCLONE_CONFIG_OFFSITE_SECRET_ACCESS_KEY={{ clickhouse_backup_s3_secret }}
RCLONE_CONFIG_OFFSITE_ENDPOINT={{ clickhouse_backup_s3_endpoint }}
RCLONE_CONFIG_OFFSITE_REGION={{ clickhouse_backup_s3_region }}
S3_BUCKET={{ clickhouse_backup_s3_bucket }}
AGE_RECIPIENT={{ clickhouse_backup_age_recipient }}
