<clickhouse>
    <!-- {{ ansible_managed }} -->
    <!-- This config.d bind mount REPLACES the image's docker_related_config.xml,
         so listen_host must be set here or the server binds to localhost only. -->
    <listen_host>0.0.0.0</listen_host>

    <tcp_port>{{ clickhouse_tcp_port }}</tcp_port>
    <http_port>{{ clickhouse_http_port }}</http_port>
{% if clickhouse_tls_enabled %}
    <tcp_port_secure>{{ clickhouse_tcp_secure_port }}</tcp_port_secure>
    <https_port>{{ clickhouse_https_port }}</https_port>
    <openSSL>
        <server>
            <certificateFile>/etc/clickhouse-server/tls/fullchain.pem</certificateFile>
            <privateKeyFile>/etc/clickhouse-server/tls/privkey.pem</privateKeyFile>
            <!-- Server presents its cert; it does not require a client cert. -->
            <verificationMode>none</verificationMode>
            <cacheSessions>true</cacheSessions>
            <disableProtocols>sslv2,sslv3,tlsv1,tlsv1_1</disableProtocols>
            <preferServerCiphers>true</preferServerCiphers>
        </server>
    </openSSL>
{% endif %}

    <timezone>{{ clickhouse_timezone }}</timezone>

    <!-- low-memory tuning -->
    <max_server_memory_usage_to_ram_ratio>{{ clickhouse_max_server_memory_ratio }}</max_server_memory_usage_to_ram_ratio>
    <mark_cache_size>134217728</mark_cache_size>
    <index_mark_cache_size>33554432</index_mark_cache_size>
    <uncompressed_cache_size>0</uncompressed_cache_size>
    <max_concurrent_queries>{{ clickhouse_max_concurrent_queries }}</max_concurrent_queries>
    <mlock_executable>false</mlock_executable>

    <background_pool_size>4</background_pool_size>
    <merge_tree>
        <!-- defaults assume background_pool_size=16 and break startup with a small pool -->
        <number_of_free_entries_in_pool_to_execute_mutation>2</number_of_free_entries_in_pool_to_execute_mutation>
        <number_of_free_entries_in_pool_to_lower_max_size_of_merge>2</number_of_free_entries_in_pool_to_lower_max_size_of_merge>
        <number_of_free_entries_in_pool_to_execute_optimize_entire_partition>2</number_of_free_entries_in_pool_to_execute_optimize_entire_partition>
    </merge_tree>
    <background_schedule_pool_size>8</background_schedule_pool_size>
    <background_buffer_flush_schedule_pool_size>2</background_buffer_flush_schedule_pool_size>
    <background_fetches_pool_size>2</background_fetches_pool_size>
    <background_common_pool_size>4</background_common_pool_size>
    <background_move_pool_size>2</background_move_pool_size>
    <background_message_broker_schedule_pool_size>2</background_message_broker_schedule_pool_size>
    <background_distributed_schedule_pool_size>2</background_distributed_schedule_pool_size>

    <!-- system log tables are not worth their disk for a pet dataset -->
    <query_log remove="remove"/>
    <query_thread_log remove="remove"/>
    <query_metric_log remove="remove"/>
    <trace_log remove="remove"/>
    <metric_log remove="remove"/>
    <asynchronous_metric_log remove="remove"/>
    <part_log remove="remove"/>
    <text_log remove="remove"/>
    <session_log remove="remove"/>
    <processors_profile_log remove="remove"/>
    <opentelemetry_span_log remove="remove"/>
    <latency_log remove="remove"/>
    <error_log remove="remove"/>
    <backup_log remove="remove"/>
    <blob_storage_log remove="remove"/>

    <logger>
        <level>warning</level>
    </logger>
</clickhouse>
