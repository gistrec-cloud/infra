#!/usr/sbin/nft -f
# {{ ansible_managed }}
# Flush only OUR table so fail2ban's inet f2b-table survives reloads.
add table inet filter
flush table inet filter

table inet filter {
    chain input {
        type filter hook input priority 0; policy drop;

        ct state established,related accept
        ct state invalid drop
        iif "lo" accept

        ip protocol icmp accept
        ip6 nexthdr ipv6-icmp accept

        tcp dport { {{ ssh_port }}, 80, 443 } accept
{% for port in firewall_extra_open_tcp_ports %}
        tcp dport {{ port }} accept
{% endfor %}
{% for rule in firewall_allow_tcp %}
        ip saddr {{ rule.from }} tcp dport {{ rule.port }} accept
{% endfor %}
{% for rule in firewall_allow_udp %}
        ip saddr {{ rule.from }} udp dport {{ rule.port }} accept
{% endfor %}
    }

    chain forward {
        type filter hook forward priority 0; policy drop;

        # Docker bridge traffic: every hooked chain must accept a packet, so
        # a bare "policy drop" here silently blackholes containers even though
        # Docker maintains its own accept rules in the ip filter table.
        ct state established,related accept
        iifname "docker0" accept
        # Compose projects bridge on br-<id>, not docker0 — without this their
        # containers' NEW outbound connections hit the drop policy (inbound
        # still works via DNAT + established, so the breakage is silent).
        iifname "br-*" accept
{% for rule in firewall_docker_allow_tcp %}
        ip saddr {{ rule.from }} tcp dport {{ rule.port }} ct state new accept
{% endfor %}
    }

    chain output {
        type filter hook output priority 0; policy accept;
    }
}
