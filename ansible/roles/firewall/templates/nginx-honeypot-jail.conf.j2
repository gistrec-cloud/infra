# {{ ansible_managed }}
# One probe of a trap path (nginx snippet honeypot.conf → honeypot.log) is
# proof of malice: ban everything immediately, escalate for repeat offenders.
[nginx-honeypot]
enabled   = true
filter    = nginx-honeypot
logpath   = /var/log/nginx/honeypot.log
# Force a file backend. The distro default is often 'systemd' (it is on
# Debian/Ubuntu), which makes the jail read the journal and miss this
# file-based honeypot log entirely — 0 hits, 0 bans. 'auto' picks
# pyinotify/polling on the file and never resolves to systemd.
backend   = auto
maxretry  = 1
# 1h first offence, default increment doubles per repeat: 1h → 2h → … → 128h.
# Soft start keeps collateral (shared Private Relay/WARP egress IPs) short;
# persistent scanners climb to the cap within days anyway. The CF sweeper's
# 8d threshold stays safely above the 128h cap.
bantime   = 3600
# Two arms: nftables cuts direct-to-origin traffic (*.vps, edalle.ru, raw IP);
# the Cloudflare action mirrors the ban as an account-wide IP Access Rule,
# because proxied vhosts always connect from CF edges and a local ban never
# touches them. Requires realip (nginx role) so <ip> is the real client.
action    = nftables-allports
{% if firewall_cf_api_token | length > 0 %}
            cloudflare-account[cftoken="{{ firewall_cf_api_token }}", cfaccount="{{ firewall_cf_account_id }}"]
{% endif %}
bantime.increment = true
bantime.maxtime   = 128h
# ignoreip comes from [DEFAULT] in jail.local (firewall_fail2ban_ignoreip).
