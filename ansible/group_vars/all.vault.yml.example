---
# Copy to all.vault.yml and encrypt:
#   ansible-vault encrypt group_vars/all.vault.yml
# The real file is gitignored. These are the keys the roles expect.

# SSH public keys installed for the admin user (common role).
vault_admin_ssh_keys:
  - "ssh-ed25519 AAAAC3Nz...REPLACE_WITH_YOUR_PUBLIC_KEY you@laptop"

# Cloudflare token for DNS-01 (tls role): scope it to DNS:Edit on exactly the
# tls_zones zones — NOT the terraform token from .envrc.
# vault_cf_acme_token: "REPLACE_ME"

# Optional: netdata health alerts → Telegram (bot via @BotFather; chat id of
# your DM with the bot or a group it is in).
# vault_netdata_telegram_bot_token: "123456789:REPLACE_ME"
# vault_netdata_telegram_chat_id: "-1001234567890"

# Optional: netdata streaming shared API key — any UUID (uuidgen).
# vault_netdata_stream_api_key: "00000000-0000-0000-0000-000000000000"

# ─── WireGuard mesh (wireguard role) ───
# One PRIVATE key per mesh host, keyed by inventory name (dashes → underscores).
# Generate: wg genkey | tee priv | wg pubkey  (public key → host_vars wireguard_pubkey).
# vault_wg_privkey_db_01: "REPLACE_ME"
# vault_wg_privkey_db_02: "REPLACE_ME"

# ─── Self-hosted MySQL (mysql role) ───
# Needed on hosts with mysql_managed: true. Avoid single quotes in any of these.
# vault_mysql_root_password:        "REPLACE_WITH_A_LONG_RANDOM_STRING"   # mandatory
# vault_mysql_replication_password: "REPLACE_ME"                          # primary + replica
# One password per app user (mirror mysql_users in host_vars):
# vault_mysql_askads:    "REPLACE_ME"
# vault_mysql_ctb:       "REPLACE_ME"
# vault_mysql_wordpress: "REPLACE_ME"
# ... one per remaining app user
