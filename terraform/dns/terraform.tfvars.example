# Copy to terraform.tfvars (gitignored) and fill with real values.
# Better: pass the token via the environment instead of a file:
#   export TF_VAR_cloudflare_api_token=...

cloudflare_api_token = "cf_REPLACE_WITH_REAL_TOKEN"

cloudflare_zone_ids = {
  "example.com" = "0123456789abcdef0123456789abcdef"
  "example.org" = "fedcba9876543210fedcba9876543210"
}

# Fleet hosts: inventory hostname => public IPv4. A records reference these
# via `host` so an IP lives in exactly one place.
host_ips = {
  "web-01" = "203.0.113.10"
  "web-02" = "203.0.113.11"
}

# Record names are FQDNs, exactly as the Cloudflare API returns them.
# A records set `host` (a host_ips key) OR a literal `content` — never both.
# Key order: zone, type, name, then host/content and the rest — records are
# grouped per zone, so every column aligns within a section.
dns_records = [
  { zone = "example.com", type = "A",     name = "example.com",     host = "web-01", proxied = true },
  { zone = "example.com", type = "CNAME", name = "www.example.com", content = "example.com", proxied = true },
  { zone = "example.com", type = "MX",    name = "example.com",     content = "mail.example.com", priority = 10 },
  { zone = "example.org", type = "A",     name = "api.example.org", content = "198.51.100.7" }, # off-fleet: literal IP
]
