# ─── Secrets & live data — NEVER commit ───────────────────────────
# Real Ansible inventory (keep only *.example)
ansible/inventory/hosts.yml

# Real per-host vars (keep only *.example)
ansible/host_vars/*.yml

# Deployed-apps registry — real app/host/repo layout (keep only *.example)
ansible/apps.yml

# Real nginx vhosts (verbatim server blocks with real domains; keep only *.example)
ansible/files/vhosts/*.conf

# Forced-command control scripts for CI deploy keys (real paths; keep only *.example)
ansible/files/bin/*
!ansible/files/bin/*.example

# Vault / secret var files (keep only *.example)
*.vault.yml
.vault_pass
.vault-password

# Per-directory env (direnv) — pulls secrets from 1Password via the op CLI
.envrc

# Raw key / certificate material (defense-in-depth alongside gitleaks)
*.pem
*.key
*.p12
*.pfx
*.keystore
id_rsa
id_ed25519
*_rsa

# Terraform variable files with real values (keep only *.example)
*.tfvars
*.auto.tfvars
*.tfvars.json
*.auto.tfvars.json

# ─── Terraform state & cache ──────────────────────────────────────
# Built function deployment artifacts
**/.dist/
**/.terraform/*
.terraform.lock.hcl
# One-shot import scaffolding (contains real resource ids)
import.tf
generated.tf
*.tfstate
*.tfstate.*
# Saved plan files may embed resource data — never commit
tfplan
*.tfplan
crash.log
crash.*.log
override.tf
override.tf.json
*_override.tf
*_override.tf.json

# ─── Misc ─────────────────────────────────────────────────────────
*.retry
*.log
.DS_Store

# scratch file backup-repo-files.sh drops at the repo root while archiving
.backup-manifest.sha256
.move-apps.state.json
